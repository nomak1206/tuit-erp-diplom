# ============================================
# ERP/CRM System — Environment Variables
# Copy this file to .env and adjust values
# ============================================

APP_NAME="ERP/CRM System"
APP_VERSION="1.0.0"
# Set to true only for development
DEBUG=false

# PostgreSQL (asyncpg for async, sync for Alembic migrations)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/erp_db
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/erp_db

# Redis (sessions, caching)
REDIS_URL=redis://localhost:6379/0

# Celery (async tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication
# ⚠️ IMPORTANT: Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — add your production domain
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Sentry (leave empty to disable)
SENTRY_DSN=

# Prometheus metrics
ENABLE_METRICS=true
